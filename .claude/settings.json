{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/workspaces/classroomio/.claude/hooks/block-github-token.sh"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'NAME=$(jq -r .name); DIR=\"/tmp/$NAME\"; git worktree add -b \"$NAME\" \"$DIR\" HEAD >&2 && echo \"$DIR\"'"
          }
        ]
      }
    ]
  }
}