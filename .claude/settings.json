{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/protect-token.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/log-tool-input.sh"
          }
        ]
      }
    ]
  },
  "WorktreeCreate": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash -c 'NAME=$(jq -r .name); DIR=\"/tmp/$NAME\"; git worktree add -b \"$NAME\" \"$DIR\" HEAD >&2 && echo \"$DIR\"'"
        }
      ]
    }
  ],
  "enabledPlugins": {
    "code-review@claude-plugins-official": true
  }
}
