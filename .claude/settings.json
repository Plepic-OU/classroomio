{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspaces/classroomio/.claude/hooks/capture-tool.sh"
          },
          {
            "type": "command",
            "command": "/workspaces/classroomio/.claude/hooks/block-token-read.sh"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'NAME=$(jq -r .name); DIR=\"/tmp/$NAME\"; git worktree add -b \"$NAME\" \"$DIR\" HEAD >&2 && echo \"$DIR\"'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true
  }
}
