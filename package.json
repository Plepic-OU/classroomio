{
  "name": "classroomio",
  "version": "0.1.13",
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run start",
    "dev": "turbo prepare --concurrency 13 && turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "clean:pnpm": "pnpm clean && pnpm store prune",
    "format": "prettier . --write",
    "release": "standard-version",
    "test:e2e": "pnpm --filter=@cio/e2e test",
    "dev:container": "turbo prepare --concurrency 13 && concurrently -n dashboard,api,website,docs -c blue,green,magenta,cyan \"cd apps/dashboard && npx vite dev --port 5173 --host\" \"cd apps/api && pnpm dev\" \"cd apps/classroomio-com && npx vite dev --port 5174 --host\" \"cd apps/docs && npx vite dev --host\"",
    "dashboard:start": "pnpm start --filter @cio/dashboard",
    "api:start": "pnpm start --filter @cio/api",
    "supabase:push": "pnpx supabase link --project-ref $PROJECT_ID && pnpx supabase db push --include-all"
  },
  "license": "MIT",
  "dependencies": {
    "turbo": "^1.10.16"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "prettier-plugin-svelte": "^3.1.2",
    "prettier-plugin-tailwindcss": "^0.5.7",
    "standard-version": "^9.5.0",
    "ts-morph": "^27.0.2",
    "tsconfig": "workspace:*",
    "tsx": "^4.20.3",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": "^20.19.3"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
