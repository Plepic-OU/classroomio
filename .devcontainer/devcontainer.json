{
  "name": "ClassroomIO",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude"
  },
  "mounts": [
    "source=classroomio-pnpm-store,target=/home/node/.local/share/pnpm/store,type=volume",
    "source=classroomio-claude-config,target=/home/node/.claude,type=volume"
  ],
  "runArgs": [
    "-p", "0.0.0.0:5173:5173",
    "-p", "0.0.0.0:5174:5174",
    "-p", "0.0.0.0:3000:3000",
    "-p", "0.0.0.0:3002:3002",
    "-p", "0.0.0.0:3333:3333",
    "-p", "0.0.0.0:9323:9323"
  ],
  "forwardPorts": [5173, 5174, 3000, 3002, 54321, 54322, 54323, 54324, 3333, 9323],
  "portsAttributes": {
    "5173": { "label": "Dashboard" },
    "5174": { "label": "Website" },
    "3000": { "label": "Docs" },
    "3002": { "label": "API" },
    "54321": { "label": "Supabase API" },
    "54322": { "label": "Supabase DB" },
    "54323": { "label": "Supabase Studio" },
    "54324": { "label": "Supabase Inbucket" },
    "3333": { "label": "Playwright UI", "onAutoForward": "notify" },
    "9323": { "label": "Playwright Report", "onAutoForward": "notify" }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "bash .devcontainer/gh-auth.sh && echo '✅ ClassroomIO devcontainer is ready. Run: pnpm dev:container'",
  "remoteUser": "node",
  "customizations": {}
}
